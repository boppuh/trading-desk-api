[Unit]
Description=Trading Desk FastAPI Backend
After=network.target clickhouse-server.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/trading-desk-api
EnvironmentFile=/home/ubuntu/trading-desk-api/.env
ExecStart=/home/ubuntu/.local/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
Environment=TZ=America/New_York

[Install]
WantedBy=multi-user.target